DATABASE_URL=postgresql+asyncpg://jarvis:password@localhost:5432/jarvis_control
REDIS_URL=redis://localhost:6379
SECRET_KEY=changeme
LOG_LEVEL=INFO
# CORS: Command Center (Vite) and typical LAN access — adjust host/IP to your machine.
# Add your LAN origin when using Command Center from another device, e.g. http://192.168.1.10:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CONTROL_PLANE_API_KEY=your-key-here
# Optional: HTTP probes for GET /api/v1/system/health (defaults suit local dev).
# JARVIS_HEALTH_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/health
# JARVIS_HEALTH_OLLAMA_URL=http://127.0.0.1:11434/api/tags
#
# Heartbeat v1 (supervision rules evaluated on POST /api/v1/heartbeat/run — optional worker in repo root heartbeat/)
# HEARTBEAT_STALLED_MISSION_MIN_AGE_HOURS=24
# HEARTBEAT_STALLED_NO_ACTIVITY_HOURS=4
# HEARTBEAT_AGING_APPROVAL_HOURS=24
# HEARTBEAT_RECEIPT_GAP_MINUTES=30
# HEARTBEAT_WORKER_STALE_MINUTES=15
#
# Governed GitHub create-issue workflow (POST /api/v1/missions/{id}/integrations/github/create-issue)
# Fine-grained PAT with Issues:write on target repo, or classic PAT with repo scope.
# JARVIS_GITHUB_TOKEN=
#
# Gmail draft workflow (POST .../integrations/gmail/create-draft) — not Composio; control-plane OAuth only.
# Use either a short-lived access token, or refresh token + OAuth client:
# JARVIS_GMAIL_ACCESS_TOKEN=
# JARVIS_GMAIL_REFRESH_TOKEN=
# JARVIS_GMAIL_CLIENT_ID=
# JARVIS_GMAIL_CLIENT_SECRET=
