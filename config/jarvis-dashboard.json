{
  "version": 1,
  "description": "JARVIS LobsterBoard template: REST endpoint specs (Bearer) plus importable LobsterBoard dashboard layout. Replace REPLACE_ME tokens from your local env; do not commit real secrets.",
  "widgetEndpoints": {
    "openclawGateway": {
      "title": "OpenClaw Gateway status",
      "url": "http://localhost:18789",
      "authorization": "Bearer REPLACE_WITH_GATEWAY_TOKEN",
      "notes": "Match token in %USERPROFILE%\\.openclaw\\openclaw.json (or JARVIS_OPENCLAW_GATEWAY_TOKEN)."
    },
    "missionControlActiveMissions": {
      "title": "Legacy Mission Control — active missions (optional)",
      "url": "http://localhost:3001/api/v1/tasks?status=active",
      "authorization": "Bearer REPLACE_WITH_MISSION_CONTROL_TOKEN",
      "refreshIntervalMs": 5000
    },
    "dashclawPendingApprovals": {
      "title": "DashClaw pending approvals",
      "url": "https://jarvis-dashclaw.vercel.app/api/approvals?status=pending",
      "authorization": "Bearer REPLACE_WITH_DASHCLAW_KEY",
      "refreshIntervalMs": 2000
    },
    "systemStats": {
      "title": "System stats (CPU, RAM)",
      "lobsterBoardEndpoint": "/api/system",
      "notes": "Served by LobsterBoard Node server on the same host."
    }
  },
  "lobsterBoard": {
    "canvas": {
      "width": 1920,
      "height": 1080
    },
    "widgets": [
      {
        "id": "jarvis-title",
        "type": "text-header",
        "x": 20,
        "y": 20,
        "width": 600,
        "height": 50,
        "properties": {
          "title": "JARVIS — LobsterBoard",
          "showHeader": false,
          "fontSize": 22,
          "fontColor": "#e6edf3",
          "textAlign": "left",
          "fontWeight": "bold"
        }
      },
      {
        "id": "jarvis-openclaw-embed",
        "type": "iframe-embed",
        "x": 20,
        "y": 90,
        "width": 600,
        "height": 420,
        "properties": {
          "title": "OpenClaw Gateway",
          "embedUrl": "http://localhost:18789/",
          "allowFullscreen": true
        }
      },
      {
        "id": "jarvis-mc-embed",
        "type": "iframe-embed",
        "x": 660,
        "y": 90,
        "width": 600,
        "height": 420,
        "properties": {
          "title": "Command Center (primary UI)",
          "embedUrl": "http://localhost:5173",
          "allowFullscreen": true
        }
      },
      {
        "id": "jarvis-dashclaw-embed",
        "type": "iframe-embed",
        "x": 1300,
        "y": 90,
        "width": 600,
        "height": 420,
        "properties": {
          "title": "DashClaw",
          "embedUrl": "https://jarvis-dashclaw.vercel.app",
          "allowFullscreen": true
        }
      },
      {
        "id": "jarvis-cpu-memory",
        "type": "cpu-memory",
        "x": 1660,
        "y": 540,
        "width": 240,
        "height": 160,
        "properties": {
          "title": "System",
          "endpoint": "/api/system",
          "refreshInterval": 5
        }
      }
    ]
  }
}
