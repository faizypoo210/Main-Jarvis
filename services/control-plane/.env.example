DATABASE_URL=postgresql+asyncpg://jarvis:password@localhost:5432/jarvis_control
REDIS_URL=redis://localhost:6379
SECRET_KEY=changeme
LOG_LEVEL=INFO
# CORS: Command Center (Vite) and typical LAN access — adjust host/IP to your machine.
# Add your LAN origin when using Command Center from another device, e.g. http://192.168.1.10:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CONTROL_PLANE_API_KEY=your-key-here
# Optional: HTTP probes for GET /api/v1/system/health (defaults suit local dev).
# JARVIS_HEALTH_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/health
# JARVIS_HEALTH_OLLAMA_URL=http://127.0.0.1:11434/api/tags
#
# Heartbeat v1 (supervision rules evaluated on POST /api/v1/heartbeat/run — optional worker in repo root heartbeat/)
# HEARTBEAT_STALLED_MISSION_MIN_AGE_HOURS=24
# HEARTBEAT_STALLED_NO_ACTIVITY_HOURS=4
# HEARTBEAT_AGING_APPROVAL_HOURS=24
# HEARTBEAT_RECEIPT_GAP_MINUTES=30
# HEARTBEAT_WORKER_STALE_MINUTES=15
#
# Cost guardrails (heartbeat cost_* findings) — evaluated on POST /api/v1/heartbeat/run from cost_events.
# Set a threshold to 0 to disable that check. Same rolling window for all.
# HEARTBEAT_COST_WINDOW_HOURS=24
# HEARTBEAT_COST_DIRECT_USD_THRESHOLD=100
# HEARTBEAT_COST_ESTIMATED_USD_THRESHOLD=100
# HEARTBEAT_COST_UNKNOWN_COUNT_THRESHOLD=50
# HEARTBEAT_COST_PROVIDER_CONCENTRATION_THRESHOLD_PCT=80
# HEARTBEAT_COST_MIN_EVENTS_FOR_CONCENTRATION=5
#
# Worker registry v1: coordinator / executor / voice / heartbeat POST to control plane with CONTROL_PLANE_API_KEY.
# Server accepts writes at POST /api/v1/workers/register and POST /api/v1/workers/heartbeat (same key as CONTROL_PLANE_API_KEY).
# On worker processes (not necessarily this file): optional JARVIS_WORKER_INSTANCE_ID, JARVIS_WORKER_HEARTBEAT_INTERVAL_SEC (default 60s, min 15s).
#
# Governed GitHub workflows (create-issue, create-pull-request, merge-pull-request) — same token.
# Fine-grained: Issues:write + Pull requests:write (merge needs merge permission); or classic PAT with repo scope.
# JARVIS_GITHUB_TOKEN=
#
# Gmail draft + reply-draft + send-draft (POST .../gmail/create-draft, create-reply-draft, send-draft) — not Composio; control-plane OAuth only.
# Same variables for all three; send-draft needs a token with gmail.send; reply-draft also needs messages.get for the referenced id (see docs/INTEGRATIONS_GMAIL.md).
# Use either a short-lived access token, or refresh token + OAuth client:
# JARVIS_GMAIL_ACCESS_TOKEN=
# JARVIS_GMAIL_REFRESH_TOKEN=
# JARVIS_GMAIL_CLIENT_ID=
# JARVIS_GMAIL_CLIENT_SECRET=
#
# SMS approval v1 (Twilio): outbound notify on new pending approval + inbound APPROVE/DENY/READ <code>
# JARVIS_SMS_APPROVALS_ENABLED=false
# JARVIS_TWILIO_ACCOUNT_SID=
# JARVIS_TWILIO_AUTH_TOKEN=
# JARVIS_TWILIO_FROM_NUMBER=+15551234567
# JARVIS_APPROVAL_SMS_TO_E164=+15559876543
# Public URL Twilio POSTs to (must match Messaging webhook URL for signature validation):
# JARVIS_TWILIO_WEBHOOK_BASE_URL=https://your-host.example.com/api/v1/integrations/sms/inbound
# JARVIS_TWILIO_INBOUND_DECIDED_BY=sms_operator
# Local dev only (never in production): skip Twilio signature check
# JARVIS_TWILIO_INBOUND_SKIP_SIGNATURE_VALIDATION=false
#
# Approval reminders + escalation v1 (runs at start of POST /api/v1/heartbeat/run; table approval_reminders)
# APPROVAL_REMINDERS_ENABLED=false
# APPROVAL_REMINDER_FIRST_MINUTES=60
# APPROVAL_REMINDER_REPEAT_MINUTES=120
# APPROVAL_ESCALATION_MINUTES=360
# APPROVAL_REMINDER_MAX_ATTEMPTS=3
# APPROVAL_REMINDER_SMS_ENABLED=true
