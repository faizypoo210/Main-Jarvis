# Copy to .env — never commit real secrets.
# Voice/WebSocket server (HTTP + WS); Command Center may derive WS URL from host + this port.
VITE_VOICE_SERVER_URL=http://localhost:8000
#
# Control plane API (browser): leave VITE_CONTROL_PLANE_URL empty to use same-origin /api/v1
# (Vite dev server proxies to the control plane and injects x-api-key from CONTROL_PLANE_API_KEY below — Node only, not bundled).
# For split-host dev, set VITE_CONTROL_PLANE_URL=http://host:8001 (mutations need server local_trusted or a reverse proxy).
VITE_CONTROL_PLANE_URL=
# Must match services/control-plane .env CONTROL_PLANE_API_KEY (used only by Vite dev proxy, not embedded in the client bundle).
CONTROL_PLANE_API_KEY=your-key-here
# Optional: override proxy target (default http://127.0.0.1:8001)
# VITE_CONTROL_PLANE_PROXY_TARGET=http://127.0.0.1:8001
#
# Runtime panel (System Health): same values as backend model role env (not bundled from server).
VITE_JARVIS_LOCAL_MODEL=qwen3.5:4b
VITE_JARVIS_CLOUD_MODEL=minimax-2.5
