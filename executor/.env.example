# Copy to .env (gitignored). Never commit .env.
CONTROL_PLANE_URL=http://localhost:8001
CONTROL_PLANE_API_KEY=your-control-plane-key-matching-services-control-plane-env
REDIS_URL=redis://localhost:6379

# Ollama (worker.py — intent classification). Match a tag from `ollama list` (e.g. Qwen 2.5 4B).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:4b
# Optional: classify request timeout in seconds
# OLLAMA_TIMEOUT_SEC=120

# Optional: override path to openclaw CLI (default: %USERPROFILE%\AppData\Roaming\npm\openclaw.cmd)
# Used only by legacy executor.py if run manually — worker.py does not use OpenClaw.
# OPENCLAW_CMD=C:\path\to\openclaw.cmd
